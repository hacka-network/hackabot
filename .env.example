# dev or production
HACKABOT_ENV=dev
DJANGO_SECRET_KEY=your_secret_key

# From @BotFather
TELEGRAM_BOT_TOKEN=your_bot_token
# Where Telegram sends updates; use an ngrok URL for local dev
TELEGRAM_WEBHOOK_URL=https://your-domain.com/webhook/telegram/
# Random string (1-256 chars, A-Za-z0-9_-) to verify webhook requests
TELEGRAM_WEBHOOK_SECRET=your_random_secret

# Optional
SENTRY_DSN=

# $10k MRR gated group (0 or unset = feature disabled)
# Chat ID of the private group joiners are verified for
# this is the ID of the TEST group (https://t.me/+pzG6FKU7OgQ4YmM0)
MRR_10K_CHAT_ID=-1004394455725
# Chat ID of the admin group that receives manual review requests
# this is the ID of the TEST group (https://t.me/+Qu_B0jz-7_I3Y2U0)
MRR_ADMIN_CHAT_ID=-5162660568
